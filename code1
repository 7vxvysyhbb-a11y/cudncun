local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VIM = game:GetService("VirtualInputManager")

local Player = Players.LocalPlayer

-- The scaling factor. 
-- 3.5 means for every 3.5 speed the ball has, it adds 1 stud to your parry range.
local SPEED_MULTIPLIER = 3.5 
local BASE_RANGE = 12 -- The absolute minimum distance to parry (for slow balls/clashes)

RunService.Stepped:Connect(function()
    local Character = Player.Character
    if not Character then return end
    
    local HRP = Character:FindFirstChild("HumanoidRootPart")
    if not HRP then return end

    -- Find the real ball
    local RealBall = nil
    for _, ball in pairs(workspace.Balls:GetChildren()) do
        if ball:GetAttribute("realBall") then
            RealBall = ball
            break
        end
    end

    if not RealBall then return end

    -- Only act if it's literally targeting you
    if RealBall:GetAttribute("target") == Player.Name then
        local Speed = RealBall.AssemblyLinearVelocity.Magnitude
        local Distance = (HRP.Position - RealBall.Position).Magnitude
        
        -- THE RELIABLE TACTIC: Speed-Scaled Range
        -- If speed is 100, range is 12 + (100/3.5) = ~40 studs.
        -- If speed is 500, range is 12 + (500/3.5) = ~154 studs.
        local DynamicRange = BASE_RANGE + (Speed / SPEED_MULTIPLIER)

        if Distance <= DynamicRange then
            -- Spam the click when inside the dynamic range
            VIM:SendMouseButtonEvent(0, 0, 0, true, game, 0)
            VIM:SendMouseButtonEvent(0, 0, 0, false, game, 0)
        end
    end
end)
