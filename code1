-- [[ SERVER EXTRAPOLATION AUTO-PARRY ]] --
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local VIM = game:GetService("VirtualInputManager")

local Player = Players.LocalPlayer
local PING_BUFFER = 0.03 -- Extra safety net for server processing

RunService.Stepped:Connect(function()
    local Character = Player.Character
    if not Character or not Character:FindFirstChild("HumanoidRootPart") then return end
    local HRP = Character.HumanoidRootPart

    -- Find the real ball
    local ActiveBall = nil
    for _, b in pairs(workspace.Balls:GetChildren()) do
        if b:GetAttribute("realBall") then 
            ActiveBall = b 
            break 
        end
    end

    if not ActiveBall then return end

    -- Only calculate if you are the target
    if ActiveBall:GetAttribute("target") == Player.Name then
        local Ping = Player:GetNetworkPing()
        local Velocity = ActiveBall.AssemblyLinearVelocity
        
        -- THE SECRET MATH:
        -- Ball.Position is where it is on YOUR screen.
        -- ServerPosition is where it actually is in the game's code.
        local ServerPosition = ActiveBall.Position + (Velocity * (Ping + PING_BUFFER))
        
        -- Measure distance to the SERVER'S ball, not the visual ball
        local TrueDistance = (HRP.Position - ServerPosition).Magnitude
        
        -- 18 studs is the sweet spot. If the server thinks the ball is within 18 studs, swing immediately.
        if TrueDistance <= 18 then
            VIM:SendMouseButtonEvent(0, 0, 0, true, game, 0)
            VIM:SendMouseButtonEvent(0, 0, 0, false, game, 0)
        end
    end
end)
