-- [[ APEX MARKET v5.0: THE SELLABLE VERSION ]] --
-- Features: Anti-Curve, Mach-Speed Scaling, Zero-Filter Logic

local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local VIM = game:GetService("VirtualInputManager")

local Player = Players.LocalPlayer

-- // COMMERICAL CONFIG //
local G_SETTINGS = {
    BASE_THRESHOLD = 15, -- Minimum distance (for slow balls)
    SPEED_SCALING = 0.35, -- How much the parry range grows with speed
    MAX_RANGE = 180,      -- Absolute max distance to parry (prevents wasting parry)
    PING_SENSE = 1.2      -- Multiplier for your lag
}

local function GetBall()
    for _, b in pairs(workspace.Balls:GetChildren()) do
        if b:GetAttribute("realBall") == true then return b end
    end
end

-- Fast execution
local function Trigger()
    VIM:SendMouseButtonEvent(0, 0, 0, true, game, 0)
    VIM:SendMouseButtonEvent(0, 0, 0, false, game, 0)
end

-- Stepped is the fastest way to beat the server
RunService.Stepped:Connect(function()
    local Char = Player.Character
    if not Char or not Char:FindFirstChild("HumanoidRootPart") then return end
    
    local Ball = GetBall()
    if not Ball then return end
    
    -- Check if it's actually coming for you
    if Ball:GetAttribute("target") == Player.Name then
        local HRP = Char.HumanoidRootPart
        local Velocity = Ball.AssemblyLinearVelocity.Magnitude
        local Distance = (HRP.Position - Ball.Position).Magnitude
        
        -- THE "UNBEATABLE" FORMULA:
        -- We calculate a 'Dynamic Hitbox' that grows as the ball accelerates.
        -- This kills curves because it doesn't care about the angle, only the distance.
        local Ping = Player:GetNetworkPing()
        local DynamicHitbox = G_SETTINGS.BASE_THRESHOLD + (Velocity * (Ping * G_SETTINGS.PING_SENSE)) + (Velocity * G_SETTINGS.SPEED_SCALING)
        
        -- Cap the hitbox so you don't parry from across the map
        if DynamicHitbox > G_SETTINGS.MAX_RANGE then
            DynamicHitbox = G_SETTINGS.MAX_RANGE
        end

        -- TRIGGER
        if Distance <= DynamicHitbox then
            Trigger()
        end
    end
end)
