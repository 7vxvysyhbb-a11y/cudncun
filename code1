-- Draggable Logic (Simple)
local dragging, dragStart, startPos
Main.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; dragStart = i.Position; startPos = Main.Position end end)
game:GetService("UserInputService").InputChanged:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseMovement and dragging then
    local d = i.Position - dragStart; Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
end end)
game:GetService("UserInputService").InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

ToggleBtn.MouseButton1Click:Connect(function()
    Apex.Enabled = not Apex.Enabled
    ToggleBtn.Text = Apex.Enabled and "SYSTEM ACTIVE" or "SYSTEM HALTED"
    ToggleBtn.TextColor3 = Apex.Enabled and Apex.Theme or Color3.fromRGB(255, 50, 50)
end)

-- // THE "GOD-MODE" LOGIC //
local function GetActiveBall()
    for _, b in pairs(workspace.Balls:GetChildren()) do
        if b:GetAttribute("realBall") then return b end
    end
end

local function ExecParry()
    VIM:SendMouseButtonEvent(0, 0, 0, true, game, 0)
    VIM:SendMouseButtonEvent(0, 0, 0, false, game, 0)
end

-- Hook into the physics step for zero-latency detection
RunService.PostSimulation:Connect(function(dt)
    if not Apex.Enabled then return end
    
    local ball = GetActiveBall()
    if not ball or not Character:FindFirstChild("HumanoidRootPart") then return end
    
    -- Real-time Physics Data
    local ballVel = ball.AssemblyLinearVelocity
    local ballPos = ball.Position
    local playerPos = HRP.Position
    local speed = ballVel.Magnitude
    local distance = (playerPos - ballPos).Magnitude
    
    -- 1. Anti-Curve / Bait Detection
    -- We calculate the Dot Product to ensure the ball is actually vectoring towards us
    local relDir = (playerPos - ballPos).Unit
    local ballDir = ballVel.Unit
    local dot = ballDir:Dot(relDir)
    
    -- 2. Advanced Timing (The Infinity Formula)
    -- account for: TimeToHit - (Ping + Static Offset + Frame Processing Time)
    local ping = Player:GetNetworkPing()
    local timeToHit = distance / speed
    local totalThreshold = ping + Apex.StaticBuffer + (dt * 0.6)

    -- 3. Execution
    if ball:GetAttribute("target") == Player.Name and dot > Apex.DetectionAngle then
        
        -- CLASH MODE (Close range panic-parry)
        if distance <= Apex.ClashRange then
            ExecParry()
            UIStroke.Color = Color3.fromRGB(255, 255, 255) -- Flash white
        
        -- PREDICTIVE MODE (Long range perfect timing)
        elseif timeToHit <= totalThreshold then
            ExecParry()
            UIStroke.Color = Color3.fromRGB(255, 255, 255)
        end
    else
        UIStroke.Color = Apex.Theme
    end
    
    -- FPS Display update
    Indicators.Text = string.format("PING: %dms | FPS: %d", math.floor(ping * 1000), math.floor(1/dt))
end)
