-- [[ OVERLORD AUTO-PARRY: NO-FILTER EDITION ]] --
-- Designed for 200 FPS | 40-60 Ping | Anti-Curve Raycasting

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local VIM = game:GetService("VirtualInputManager")

local Player = Players.LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local HRP = Character:WaitForChild("HumanoidRootPart")

-- // THE "BEST" CONFIG //
local Config = {
    Enabled = true,
    -- Timing: Lower = Closer to body, Higher = Further away
    -- With 50 ping, 0.035 is usually the "God Spot"
    TimingBuffer = 0.035, 
    ClashDistance = 18, -- Buffed for fast spammers
}

-- // MINIMALIST PRO GUI //
local ScreenGui = Instance.new("ScreenGui", Player.PlayerGui)
local Frame = Instance.new("Frame", ScreenGui)
Frame.Size = UDim2.new(0, 150, 0, 50)
Frame.Position = UDim2.new(0.5, -75, 0, 10)
Frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
Frame.BackgroundTransparency = 0.5

local Toggle = Instance.new("TextButton", Frame)
Toggle.Size = UDim2.new(1, 0, 1, 0)
Toggle.Text = "OVERLORD: ACTIVE"
Toggle.TextColor3 = Color3.fromRGB(0, 255, 100)
Toggle.BackgroundTransparency = 1
Toggle.Font = Enum.Font.Code

Toggle.MouseButton1Click:Connect(function()
    Config.Enabled = not Config.Enabled
    Toggle.Text = Config.Enabled and "OVERLORD: ACTIVE" or "OVERLORD: OFF"
    Toggle.TextColor3 = Config.Enabled and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(255, 50, 50)
end)

-- // ELITE EXECUTION //
local function GetBall()
    for _, b in pairs(workspace.Balls:GetChildren()) do
        if b:GetAttribute("realBall") then return b end
    end
end

-- Fast parry trigger
local function Hit()
    VIM:SendMouseButtonEvent(0, 0, 0, true, game, 0)
    VIM:SendMouseButtonEvent(0, 0, 0, false, game, 0)
end

-- Using Heartbeat (Runs every physics frame)
RunService.Heartbeat:Connect(function(dt)
    if not Config.Enabled then return end
    
    local Ball = GetBall()
    if not Ball or not Character:FindFirstChild("HumanoidRootPart") then return end
    
    local Velocity = Ball.AssemblyLinearVelocity
    local Speed = Velocity.Magnitude
    local BallPos = Ball.Position
    local PlayerPos = HRP.Position
    local Distance = (PlayerPos - BallPos).Magnitude
    
    -- IS IT TARGETING ME? (Keep this simple, don't overthink)
    local IsTarget = (Ball:GetAttribute("target") == Player.Name)
    
    if IsTarget then
        -- TIME TO IMPACT
        local TTI = Distance / Speed
        local Ping = Player:GetNetworkPing()
        
        -- DYNAMIC THRESHOLD (The secret sauce)
        -- We combine Ping + Fixed Buffer + Frame Time
        local Threshold = Ping + Config.TimingBuffer + (dt * 0.5)

        -- TRIGGER CONDITIONS
        -- 1. Calculated Timing (Long/Mid Range)
        if TTI <= Threshold then
            Hit()
        -- 2. Emergency Distance (Close Range / Clash)
        elseif Distance <= Config.ClashDistance then
            Hit()
        end
    end
end)
